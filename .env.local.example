# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Convex
# Get this from https://dashboard.convex.dev after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=https://...convex.cloud

# Clerk domain for Convex auth
# Found in Clerk dashboard → JWT Templates → Convex → Issuer URL
NEXT_PUBLIC_CLERK_DOMAIN=https://...clerk.accounts.dev
